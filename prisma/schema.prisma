generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. USER & AUTHENTICATION LAYER (UPDATED)
// ==========================================
model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String?
  passwordHash     String?        // <-- MISSING: Required for native login
  authProvider     String         @default("LOCAL") // <-- MISSING: "LOCAL", "GOOGLE", "GITHUB"
  isEmailVerified  Boolean        @default(false)   // <-- MISSING: Security health check
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  profile          UserProfile?
  resumes          Resume[]
  githubProfile    GithubProfile?
  roadmaps         Roadmap[]
  applications     JobApplication[]
  preferences      UserPreference?
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?  
  skills      String[] 
  experience  Json?    
  education   Json?    
}

model UserPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleTypes    String[] 
  locations    String[] 
  minSalary    Int?
  autoApply    Boolean  @default(false) 
}

// ==========================================
// 2. RESUME & GITHUB ANALYSIS LAYER (UPDATED)
// ==========================================
model Resume {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl     String
  parsedText  String?     
  isMain      Boolean     @default(false) // <-- MISSING: Tells the bot which resume to send
  createdAt   DateTime    @default(now())
  
  atsScans    AtsScan[]

  @@index([userId]) // <-- MISSING: Speeds up finding a user's resumes
}

model AtsScan {
  id            String   @id @default(uuid())
  resumeId      String
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  targetJobRole String
  overallScore  Int      
  keywordGaps   String[] 
  projectFixes  Json     
  rawFeedback   Json     
  scannedAt     DateTime @default(now())

  @@index([resumeId])
}

model GithubProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username      String
  encryptedToken String?  // <-- MISSING: For background workers to access GitHub API securely
  totalCommits  Int      @default(0)
  topLanguages  String[]
  repositories  Json     
  lastSyncedAt  DateTime @default(now())
}

// ==========================================
// 3. JOB DISCOVERY & AUTOMATION LAYER (UPDATED)
// ==========================================
model JobListing {
  id             String           @id @default(uuid())
  title          String
  company        String
  location       String
  sourcePlatform String          
  externalUrl    String           @unique
  description    String
  requiredSkills String[]
  salaryRange    String?
  isActive       Boolean          @default(true) // <-- MISSING: Stops bots from applying to dead jobs
  postedAt       DateTime
  createdAt      DateTime         @default(now()) 
  
  applications   JobApplication[]

  @@index([sourcePlatform]) // <-- MISSING: Speeds up your dashboard charts
}

model JobApplication {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId    String
  jobListing      JobListing        @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  status          ApplicationStatus @default(PENDING) 
  rejectionReason String?           // <-- MISSING: Metric to tell AI why it was rejected
  coverLetter     String?           
  isAutonomous    Boolean           @default(false)   
  appliedAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  history         ApplicationHistory[] // <-- MISSING: Connects to history tracking entries

  @@index([userId])
  @@index([jobListingId])
}

// <-- MISSING MODEL: Tracks the lifecycle of an application over time
model ApplicationHistory {
  id            String            @id @default(uuid())
  applicationId String
  application   JobApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  oldStatus     ApplicationStatus?
  newStatus     ApplicationStatus
  changedAt     DateTime          @default(now())

  @@index([applicationId])
}

enum ApplicationStatus {
  PENDING
  APPLIED
  RECRUITER_CONTACT
  INTERVIEWING
  OFFER
  REJECTED
}

// ==========================================
// 4. ROADMAP & UPSKILLING LAYER (UPDATED)
// ==========================================
model Roadmap {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  milestones  Milestone[]

  @@index([userId])
}

model Milestone {
  id          String   @id @default(uuid())
  roadmapId   String
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  title       String   
  description String?
  order       Int      
  isCompleted Boolean  @default(false)
  
  courses     Course[]

  @@index([roadmapId])
}

model Course {
  id          String    @id @default(uuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  title       String
  platform    String    
  url         String
  isCompleted Boolean   @default(false) 

  @@index([milestoneId])
}
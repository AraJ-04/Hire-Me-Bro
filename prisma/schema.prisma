generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================
enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

enum ApplicationStatus {
  SAVED             // <-- NEW: Bookmarked for later review
  PENDING           // Bot is queued to apply or user is drafting
  APPLIED
  RECRUITER_CONTACT
  INTERVIEWING
  OFFER
  REJECTED
}

enum LogStatus {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum ActionItemType {
  RESUME_TWEAK
  SKILL_GAP
  PORTFOLIO_UPDATE
  GITHUB_SUGGESTION
}

enum FeedbackSeverity {
  SUCCESS
  INFO
  WARNING
  ERROR
}

enum SyncStatus {
  IDLE
  SCANNING
  COMPLETED
  FAILED
}

enum MilestoneStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum CourseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ==========================================
// 1. USER, AUTH, & BILLING LAYER
// ==========================================
model User {
  id               String                @id @default(uuid())
  email            String                @unique
  name             String?
  passwordHash     String?              
  authProvider     String                @default("LOCAL") 
  isEmailVerified  Boolean               @default(false)   
  
  subscriptionTier SubscriptionTier      @default(FREE)
  stripeCustomerId String?               @unique
  aiTokens         Int                   @default(5) 
  
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  
  // Relations
  profile          UserProfile?
  preferences      UserPreference?
  resumes          Resume[]
  githubProfile    GithubProfile?
  roadmaps         Roadmap[]
  applications     JobApplication[]
  apiKeys          UserApiKey[]
  integrations     PlatformIntegration[] 
  
  recommendations  JobRecommendation[]
  aiActionItems    AiActionItem[]
  voiceTranscriptions VoiceTranscription[]
}

model UserApiKey {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   
  encryptedKey String
  createdAt    DateTime @default(now())

  @@unique([userId, provider]) 
}

model PlatformIntegration {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platformName   String   // e.g., "LINKEDIN", "UNSTOP", "INTERNSHALA"
  isConnected    Boolean  @default(false)
  sessionCookie  String?  
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, platformName])
}

model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileImageUrl String?
  currentJobTitle String?
  location        String?

  bio             String?  
  skills          String[] 
  experience      Json?    
  education       Json?    
}

model VoiceTranscription {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rawTranscript    String   @db.Text
  insightGenerated String?  @db.Text
  confidenceScore  Int      @default(0)

  createdAt        DateTime @default(now())

  @@index([userId])
}

model UserPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  roleTypes          String[] 
  locations          String[] 
  minSalary          Int?
  
  autoApply          Boolean  @default(false) 
  autoApplyThreshold Int      @default(90)    
  
  enableSmtp         Boolean  @default(false) 
  outreachTemplate   String?  @db.Text        
}

// ==========================================
// 2. DASHBOARD INTELLIGENCE LAYER
// ==========================================
model JobRecommendation {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId    String
  jobListing      JobListing  @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  
  matchScore      Int         
  matchReason     String?     
  isDismissed     Boolean     @default(false)
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@unique([userId, jobListingId]) 
}

model AiActionItem {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            ActionItemType 
  title           String         
  description     String         
  relatedJobId    String?        
  isCompleted     Boolean        @default(false) 
  createdAt       DateTime       @default(now())
  @@index([userId])
}

// ==========================================
// 3. RESUME & GITHUB ANALYSIS LAYER
// ==========================================
model Resume {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName   String    
  fileUrl    String
  parsedText String?   
  isMain     Boolean   @default(false) 
  createdAt  DateTime  @default(now())
  atsScans   AtsScan[]
  @@index([userId]) 
}

model AtsScan {
  id            String   @id @default(uuid())
  resumeId      String
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  targetJobRole String
  overallScore  Int      
  summaryText   String?  
  keywordGaps   String[] 
  feedback      ResumeFeedback[] 
  scannedAt     DateTime @default(now())
  @@index([resumeId])
}

model ResumeFeedback {
  id            String           @id @default(uuid())
  scanId        String
  atsScan       AtsScan          @relation(fields: [scanId], references: [id], onDelete: Cascade)
  severity      FeedbackSeverity 
  category      String           
  title         String           
  description   String           
  boundingBox   Json?            
  createdAt     DateTime         @default(now())
  @@index([scanId])
}

model GithubProfile {
  id               String             @id @default(uuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  username         String
  encryptedToken   String?  
  syncStatus       SyncStatus         @default(IDLE)
  syncProgress     Int                @default(0) 
  totalCommits     Int                @default(0)
  topLanguages     String[]
  commitFrequency  String?            
  relevancyScore   Int?               
  activityData     Json?              
  lastSyncedAt     DateTime           @default(now())
  repositories     GithubRepository[]
}

model GithubRepository {
  id               String        @id @default(uuid())
  profileId        String
  githubProfile    GithubProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  repoName         String        
  description      String?
  primaryLanguage  String?       
  stars            Int           @default(0)
  isPrivate        Boolean       @default(false)
  isIncludedInScan Boolean       @default(true) 
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  @@index([profileId])
}

// ==========================================
// 4. JOB DISCOVERY & AUTOMATION LAYER
// ==========================================
model JobListing {
  id             String           @id @default(uuid())
  title          String
  company        String
  location       String
  sourcePlatform String           
  externalUrl    String           @unique
  description    String
  requiredSkills String[]
  salaryRange    String?
  
  employmentType String?          
  experienceLevel String?         
  tags           String[]         

  isActive       Boolean          @default(true) 
  postedAt       DateTime
  createdAt      DateTime         @default(now()) 
  
  applications   JobApplication[]
  recommendations JobRecommendation[] 

  @@index([sourcePlatform]) 
}

model JobApplication {
  id              String               @id @default(uuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId    String
  jobListing      JobListing           @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  
  status          ApplicationStatus    @default(SAVED) // <-- Default changed to SAVED
  rejectionReason String?              
  coverLetter     String?              
  isAutonomous    Boolean              @default(false)   
  
  appliedAt       DateTime?            // <-- Made optional for saved state
  updatedAt       DateTime             @updatedAt

  history         ApplicationHistory[] 
  interviews      Interview[]
  automationLogs  AutomationLog[]

  @@index([userId])
  @@index([jobListingId])
}

model ApplicationHistory {
  id            String             @id @default(uuid())
  applicationId String
  application   JobApplication     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  oldStatus     ApplicationStatus?
  newStatus     ApplicationStatus
  changedAt     DateTime           @default(now())
  @@index([applicationId])
}

// ==========================================
// 5. INTERVIEW TRACKING & LOGS
// ==========================================
model Interview {
  id            String          @id @default(uuid())
  applicationId String
  application   JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  roundName     String          
  scheduledAt   DateTime
  interviewer   String?
  notes         String?         
  prepQuestions InterviewPrep[] 
  createdAt     DateTime        @default(now())
  @@index([applicationId])
}

model InterviewPrep {
  id              String    @id @default(uuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question        String
  suggestedAnswer String?   
  createdAt       DateTime  @default(now())
  @@index([interviewId])
}

model AutomationLog {
  id            String         @id @default(uuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  step          String         
  status        LogStatus      @default(INFO)
  message       String         
  screenshotUrl String?        
  createdAt     DateTime       @default(now())

  @@index([applicationId])
}

// ==========================================
// 6. ROADMAP & UPSKILLING LAYER 
// ==========================================
model Roadmap {
  id                   String      @id @default(uuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole           String
  targetCompany        String?     
  deadlineMonths       Int         @default(6)
  remindersEnabled     Boolean     @default(true)
  competitionLevel     String?     
  estimatedSalaryRange String?     
  aiOptimizationNotes  String?     
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  milestones           Milestone[]
  @@index([userId])
}

model Milestone {
  id          String          @id @default(uuid())
  roadmapId   String
  roadmap     Roadmap         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  title       String          
  description String?
  order       Int      
  status      MilestoneStatus @default(LOCKED)
  progress    Int             @default(0) 
  courses     Course[]
  @@index([roadmapId])
}

model Course {
  id          String       @id @default(uuid())
  milestoneId String
  milestone   Milestone    @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  title       String       
  platform    String       
  url         String
  duration    String?      
  price       String?      
  status      CourseStatus @default(NOT_STARTED)
  @@index([milestoneId])
}
